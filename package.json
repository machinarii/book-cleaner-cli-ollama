{
  "name": "book-cleaner-cli",
  "version": "0.1.0",
  "description": "CLI tool for transforming raw book sources into clean, readable Markdown with comprehensive metadata",
  "main": "dist/src/index.js",
  "bin": {
    "clean-book": "dist/src/index.js"
  },
  "scripts": {
    "build": "swc src -d dist --config-file .swcrc && chmod +x dist/src/index.js",
    "build:watch": "swc src -d dist --config-file .swcrc --watch",
    "dev": "node -r @swc-node/register src/index.ts",
    "dev:watch": "node -r @swc-node/register --watch src/index.ts",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "analyze-structure": "node -r @swc-node/register scripts/analyze-book-structure.ts",
    "test-format-detection": "node -r @swc-node/register scripts/test-format-detection.ts",
    "test:step1-2": "node -r @swc-node/register scripts/test-step1-2.ts",
    "test:pipeline-results": "node -r @swc-node/register scripts/test-pipeline-results.ts",
    "fix-ts": "node scripts/fix-ts-resolution.js",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "cli",
    "book",
    "text-processing",
    "pdf",
    "epub",
    "ocr",
    "markdown",
    "typescript",
    "ollama"
  ],
  "author": "Michael Schmidt",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "commander": "^14.0.3",
    "epub2": "^3.0.2",
    "glob": "^13.0.6",
    "js-yaml": "^4.1.1",
    "mime-types": "^3.0.2",
    "ora": "^9.3.0",
    "pdf-parse": "^1.1.1",
    "pdf2pic": "^3.2.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@swc-node/register": "^1.11.1",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.26",
    "@swc/jest": "^0.2.39",
    "@types/cli-progress": "^3.11.6",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^24.0.0",
    "@types/pdf-parse": "^1.1.5",
    "jest": "^30.3.0",
    "prettier": "^3.8.3",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ]
}
